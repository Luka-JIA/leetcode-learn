int climbStairs(int n) {
    int result=0;
    if(n==1){
        result=1;
        return result;
    }
    else if(n==2){
        result=2;
        return result;
    }
    else{
        result+=climbStairs(n-1)+climbStairs(n-2);
        return result;
    }
}

##when o(n)->o(1):

int climbStairs(int n) {
    int fir=0,sec=0,re=1;
    for(int i=1;i<=n;i++){
        fir=sec;
        sec=re;
        re=fir+sec;
    }
    return re;
}
